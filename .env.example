# ─── CMS Crew Management System — Environment Variables ───
# Developer: Ahtjong Labs

# ─── Database ───
# LOCAL DEV (SQLite):
DATABASE_URL="file:../db/custom.db"

# VERCEL/NEON (PostgreSQL):
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ─── Auth ───
# JWT secret for stateless authentication — MUST be set in Vercel!
# Generate one: openssl rand -base64 32
NEXT_AUTH_SECRET="change-this-to-a-random-32-char-string"

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── VERCEL DEPLOY CHECKLIST ───
# 1. Set DATABASE_URL to your Neon PostgreSQL connection string
# 2. Set NEXT_AUTH_SECRET to a random 32+ character string
# 3. Change prisma/schema.prisma provider from "sqlite" to "postgresql"
# 4. Run: npx prisma db push (after changing provider)
